# =============================================================================
# TF-GRPO-Opt-Baseline-72B 运行命令
# 模型：Qwen2.5-Math-72B-Instruct（本地）  设备：昇腾 NPU × 8
# device_map="auto" 自动将模型分片到所有可见 NPU，无需 torchrun
# =============================================================================

# ── 构建经验库 ────────────────────────────────────────────────────────────────
python build_experience.py \
    --model /mnt/nvme0/models/Qwen2.5-Math-72B-Instruct \
    --data_path /data/jbliang/dapo-math-17k.parquet \
    --sample_size 100 \
    --group_size 4 \
    --epochs 3 \
    --max_new_tokens 2048 \
    --device npu:0 \
    --output_dir ./output_logs

# ── 推理评估（带经验库，TF-GRPO 模式）────────────────────────────────────────
python math_inference.py \
    --model /mnt/nvme0/models/Qwen2.5-Math-72B-Instruct \
    --dataset gsm8k \
    --data_path ./dataset/gsm8k/test.json \
    --save_path ./results/gsm8k_tfgrpo_72b.json \
    --experience_bank_path ./output_logs/experience_bank_epoch_3.json \
    --device npu:0 \
    --IF_TF_GRPO_MODE

# ── 推理评估（Zero-shot，对照组）─────────────────────────────────────────────
python math_inference.py \
    --model /mnt/nvme0/models/Qwen2.5-Math-72B-Instruct \
    --dataset gsm8k \
    --data_path ./dataset/gsm8k/test.json \
    --save_path ./results/gsm8k_zeroshot_72b.json \
